  "cubes": {
    "ProjectCube": {
      "display_name": "项目实体Cube",
      "description": "项目主数据Cube",
      "table_name": "dim_project",
      "dimensions": [
        "id",
        "projectCode",
        "projectName",
        "projectType",
        "projectStatus",
        "province",
        "city",
        "companyId"
      ],
      "measures": [
        "contractAmount"
      ]
    },
    "ProjectOutputCube": {
      "display_name": "项目产值Cube",
      "description": "项目产值分析Cube",
      "table_name": "fact_project_output",
      "dimensions": [
        "id",
        "projectId",
        "reportPeriod",
        "outputType"
      ],
      "measures": [
        "outputValue",
        "outputTax",
        "outputWithoutTax",
        "outputRatio"
      ],
      "derived_measures": [
        {
          "name": "outputGrowthRate",
          "expression": "同比增长率(outputValue)"
        }
      ]
    },
    "ProjectCostCube": {
