{
  "name": "@dazi/runtime-apps-workspace",
  "private": true,
  "version": "0.1.0",
  "description": "DRAP（Dazi Runtime App Platform）SDK / 模板 / CLI monorepo（见 dazi/docs/305-Dazi-RuntimeAppPlatform方案.md）",
  "scripts": {
    "build": "pnpm -r --filter='./sdk/*' --filter='./templates/*' build",
    "dev:profit-analysis": "pnpm --filter @dazi/app-template-profit-analysis-dashboard dev",
    "build:profit-analysis": "pnpm --filter @dazi/app-template-profit-analysis-dashboard build",
    "preview:profit-analysis": "pnpm --filter @dazi/app-template-profit-analysis-dashboard exec vite preview --port 5181 --host --strictPort",
    "bundle:clis": "pnpm --dir ../dazi-vscode run bundle:clis",
    "dazi-app": "dazi-app"
  },
  "devDependencies": {
    "@dazi/dazi-app-cli": "workspace:*",
    "typescript": "~5.6.3"
  },
  "engines": {
    "pnpm": ">=8"
  }
}
