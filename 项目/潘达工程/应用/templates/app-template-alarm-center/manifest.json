{
  "appId": "alarm-center",
  "name": "告警中心",
  "description": "告警中心（DRAP 页模式演示模板）",
  "version": "0.1.0",
  "framework": {
    "react": "^18",
    "ts": true
  },
  "entry": "index.html",
  "styles": [
    "style.css"
  ],
  "assets": [
    "assets/"
  ],
  "permissions": [
    "dataspace:space__0519"
  ],
  "data_sources": [
    {
      "key": "alarms",
      "kind": "static",
      "data": {
        "columns": [
          "level",
          "source",
          "message",
          "time",
          "status"
        ],
        "rows": [
          {
            "level": "高",
            "source": "产线A",
            "message": "温度超限",
            "time": "10:02",
            "status": "未确认"
          },
          {
            "level": "中",
            "source": "仓储",
            "message": "库存低于安全线",
            "time": "09:45",
            "status": "处理中"
          }
        ]
      }
    }
  ],
  "sdk": {
    "min_version": "0.1.0",
    "contract": "drap-1"
  },
  "mount": {
    "type": "page",
    "sandbox": "shadow_dom"
  },
  "refresh": {
    "on_mount": true,
    "stale_ms": 60000
  },
  "ai": {
    "scene_tag": "alarm",
    "template_origin": "@dazi/app-template-alarm-center@0.1.0"
  }
}
