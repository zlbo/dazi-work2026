{
  "appId": "profit-analysis",
  "name": "利润分析",
  "description": "月度营收/利润 KPI 与趋势看板（FC02 本体数据）",
  "version": "0.1.0",
  "framework": { "react": "^18", "ts": true },
  "entry": "index.html",
  "styles": ["style.css"],
  "assets": ["assets/"],
  "routes": ["/runtime-apps/profit-analysis"],
  "permissions": [
    "dataspace:space__0519",
    "ontology_function:fc02.fn.month_pl_budget_kpi",
    "ontology_semantic:FinPLMonthFact"
  ],
  "data_sources": [
    {
      "key": "kpi",
      "kind": "ontology_function",
      "function_id": "fc02.fn.month_pl_budget_kpi",
      "object_type_code": "FinPLMonthFact",
      "arguments": { "year_month": "2024-06", "version_id": 1 }
    },
    {
      "key": "trend",
      "kind": "cube_query",
      "measures": ["cube_fin_cockpit02_profit.amount"],
      "dimensions": ["cube_fin_cockpit02_profit.year_month"],
      "filters": [
        {
          "member": "cube_fin_cockpit02_profit.year_key",
          "operator": "equals",
          "values": ["2024"]
        }
      ],
      "limit": 12
    },
    {
      "key": "yoy_table",
      "kind": "static",
      "data": { "columns": [], "rows": [] }
    }
  ],
  "sdk": { "min_version": "0.1.0", "contract": "drap-1" },
  "mount": { "type": "page", "sandbox": "shadow_dom" },
  "refresh": { "on_mount": true, "stale_ms": 60000 },
  "ai": {
    "scene_tag": "profit_analysis_dashboard",
    "industry": ["chemical", "manufacturing"],
    "template_origin": "@dazi/app-template-profit-analysis-dashboard@0.1.0"
  }
}
