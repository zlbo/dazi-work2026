      "data": {
        "label": "数据质量检查",
        "type": "data-quality-check",
        "flowId": 103,
        "output_variable_name": "V_DQ_REPORT",
        "attached_variables": [
          "产品表",
          "规格表"
        ],
        "qualityConfig": {
          "fail_on_error": false,
          "comment": "不抛错；由下游条件节点根据 V_DQ_REPORT 决定是继续 SQL 还是直接结束",
          "rules": [
            {
              "name": "销售表行数",
              "type": "row_count_min",
              "table": "销售表",
              "min": 1,
              "description": "事实表不能为空，至少 1 行销售记录"
            },
            {
              "name": "产品表行数",
              "type": "row_count_min",
              "table": "产品表",
              "min": 1,
              "description": "产品维表不能为空，至少 1 个 SKU"
            },
            {
              "name": "规格表行数",
              "type": "row_count_min",
              "table": "规格表",
              "min": 1,
              "description": "规格维表不能为空，至少 1 个规格"
            },
            {
              "name": "销售表.产品非空",
              "type": "not_null",
              "table": "销售表",
              "column": "产品",
              "description": "每条销售须带产品编码（如 P01），不可为空"
            },
            {
              "name": "销售表.规格非空",
              "type": "not_null",
              "table": "销售表",
              "column": "规格",
              "description": "每条销售须带规格编码（如 S1），不可为空"
            },
            {
              "name": "销售表.地区非空",
              "type": "not_null",
              "table": "销售表",
              "column": "地区",
              "description": "每条销售须带销售区域（如 华东），不可为空"
            },
            {
              "name": "外键匹配",
              "type": "fk_match",
              "description": "销售表.产品→产品表.ID、销售表.规格→规格表.ID，维表须能关联"
            }
          ]
        },
        "description": "检查销售表/产品表/规格表行数、关键字段非空及外键完整性"
