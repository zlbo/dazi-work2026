    {
      "id": "n-bbf0b016cb06",
      "type": "custom",
      "position": {
        "x": 392,
        "y": 336
      },
      "data": {
        "label": "数据质量检查",
        "type": "data-quality-check",
        "flowId": 112,
        "output_variable_name": "V_DQ_REPORT",
        "attached_variables": [
          "产品表"
        ],
        "qualityConfig": {
          "fail_on_error": false,
          "comment": "检查销售表/产品表行数、关键字段非空及外键完整性",
          "rules": [
            {
              "name": "销售表行数",
              "type": "row_count_min",
              "table": "销售表",
              "min": 1,
              "description": "事实表不能为空，至少 1 行销售记录"
            },
            {
              "name": "产品表行数",
              "type": "row_count_min",
              "table": "产品表",
              "min": 1,
              "description": "产品维表不能为空，至少 1 个 SKU"
            },
            {
              "name": "销售表.产品非空",
              "type": "not_null",
              "table": "销售表",
              "column": "产品",
              "description": "每条销售须带产品编码，不可为空"
            },
            {
              "name": "销售表.地区非空",
              "type": "not_null",
              "table": "销售表",
              "column": "地区",
              "description": "每条销售须带销售区域，不可为空"
            },
            {
              "name": "外键匹配",
              "type": "fk_match",
              "description": "销售表.产品 → 产品表.ID，维表须能关联"
            }
          ]
        },
        "description": "检查销售表/产品表行数、关键字段非空及外键完整性"
      },
      "deletable": true,
