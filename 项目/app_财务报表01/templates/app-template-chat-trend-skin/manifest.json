{
  "appId": "chat-trend-skin",
  "name": "聊天问数趋势皮肤",
  "description": "问数主区趋势图：从 message 数据集自动推断维度列与数值列",
  "version": "0.1.0",
  "framework": { "react": "^18", "ts": true },
  "entry": "index.html",
  "styles": ["style.css"],
  "assets": ["assets/"],
  "permissions": ["dataspace:space__0519"],
  "data_sources": [
    {
      "key": "message",
      "kind": "static",
      "data": {
        "columns": ["month", "revenue", "profit"],
        "rows": [
          { "month": "1月", "revenue": 980000, "profit": 120000 },
          { "month": "2月", "revenue": 1020000, "profit": 135000 },
          { "month": "3月", "revenue": 1100000, "profit": 148000 }
        ]
      }
    },
    {
      "key": "trend",
      "kind": "static",
      "data": {
        "columns": ["month", "revenue", "profit"],
        "rows": [
          { "month": "1月", "revenue": 980000, "profit": 120000 },
          { "month": "2月", "revenue": 1020000, "profit": 135000 },
          { "month": "3月", "revenue": 1100000, "profit": 148000 }
        ]
      }
    }
  ],
  "sdk": { "min_version": "0.1.0", "contract": "drap-1" },
  "mount": { "type": "chat_result", "sandbox": "shadow_dom" },
  "refresh": { "on_mount": false },
  "ai": {
    "scene_tag": "chat_trend_skin",
    "template_origin": "@dazi/app-template-chat-trend-skin@0.1.0"
  }
}
